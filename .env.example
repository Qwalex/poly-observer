# Wallet that holds open positions (Data API). Defaults to USER_ADDRESS, then RELAYER_API_KEY_ADDRESS.
# POSITIONS_USER_ADDRESS=0x...

# Your Polymarket profile / trading address
USER_ADDRESS=0x0000000000000000000000000000000000000000

# Relayer API (Settings → API Keys). Optional for position polling; required for relayer endpoints.
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# Alert when unrealized profit is at or above this percent
PROFIT_THRESHOLD_PERCENT=20

# Telegram bot (TELEGREM_BOT_API — supported typo from .env)
TELEGREM_BOT_API=
# TELEGRAM_BOT_API=
# Fixed chat for alerts (optional; otherwise /start in bot)
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_ALLOWED_CHAT_IDS=123456789

# HTTP notification endpoint (set NOTIFY_HTTP_ENABLED=false to disable)
NOTIFY_URL=https://notify.qwalex.one
NOTIFY_HTTP_ENABLED=true
NOTIFY_INTERVAL_MS=5000

# How often to refresh positions from Data API (ms)
POSITIONS_POLL_INTERVAL_MS=30000

# Railway sets PORT automatically; local default:
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Legacy alias for USER_ADDRESS
# POLYMARKET_USER_ADDRESS=0x...

# Optional overrides
# DATA_API_BASE_URL=https://data-api.polymarket.com
# MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
